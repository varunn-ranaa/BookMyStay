<% layout("/layouts/boilerplate")%>

    <div class="row">
         <div class="col-12 col-md-8 col-lg-6 offset-md-1 offset-lg-3">
            <h3>Listing Details </h3>
         </div>
         <hr>
         <div class="col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3">
         <div class="card listing-card show-card" >
            <img class="card-img-top prop-img " src="<%=list.image.url%>" alt="property-img">
            <div class="card-body">
              <div class="mt-3">
                <p class="card-text"><b><%=list.title%></b></p>
              </div>
              <div class="mt-3">
                 <p class="card-text"><b>Description : </b><i><%=list.description%></i></p>
              </div>
              <div class="mt-3">
                 <p class="card-text"><b>Price :</b> &#8377; <%=list.price.toLocaleString("en-in")%></p>
              </div>
              <div class="mt-3">
                <p class="card-text"><b>Location : </b><%=list.location%></p>
              </div>
              <div class="mt-3">
                <p class="card-text"><b>Country :</b> <%= list.country %></p>
              </div>
              <div class="show-btns mt-3">
                  <a href="http://localhost:8080/listing/<%=list._id%>/edit" class="btn btn-dark edit-btn">Edit</a>
                  <form method="post" action="/listing/<%=list._id%>?_method=DELETE">
                  <button type="submit" class="btn btn-dark del-btn">Delete</button>
                </form>
              </div> 
            </div>
         </div>
         </div>
         <hr/>

         <div class="col-12 col-md-10 col-lg-8 offset-md-2 offset-lg-3">
          <h4 class="ms-2">Reviews and Ratings</h4>       
            <div class="row">
              <% for(let review of list.review) { %>
              <div class="card col-5 ms-4 mt-2 mb-2">
                <div class="card-body">
                  <h6 class="card-title"><b>anonymous</b></h6>
                  <p class="card-text"><%= review.comment %></p>
                  <!-- <p class="card-text"><%= review.rating%>stars</p> -->
                  <div class="mb-2">
                  <% for(let i = 1; i <= 5; i++) { %>
                  <% if(i <= review.rating) { %>
                  <i class="fa-solid fa-star text-warning"></i>
                  <% } else { %>
                  <i class="fa-regular fa-star text-warning"></i>
                  <% } %>
                  <% } %>
                  </div>

                </div>
              </div>
              <% } %>
            </div>      
            
            <hr>
            
            <h4>Add review</h4>
            <form method="post" action="/listing/<%=list._id%>/reviews" class="needs-validation" novalidate>
                <div class="mb-2">
                    <label for="rating" class="form-label"><b>Rating :</b></label>
                     <div class="star-rating">
                     <input type="radio" name="review[rating]" id="star5" value="5">
                     <label for="star5"><i class="fa fa-star" aria-hidden="true"></i></label>

                    <input type="radio" name="review[rating]" id="star4" value="4">
                    <label for="star4"><i class="fa fa-star" aria-hidden="true"></i></label>

                    <input type="radio" name="review[rating]" id="star3" value="3">
                    <label for="star3"><i class="fa fa-star" aria-hidden="true"></i></label>

  
                    <input type="radio" name="review[rating]" id="star2" value="2">
                    <label for="star2"><i class="fa fa-star" aria-hidden="true"></i></label>
         
                    <input type="radio" name="review[rating]" id="star1" value="1">
                    <label for="star1"><i class="fa fa-star" aria-hidden="true"></i></label>
                    </div>
                </div>
                 <div class="mb-2">
                     <label for="review" class="form-label"><b>Write your review :</b></label>
                     <textarea name="review[comment]" id="review" class="form-control" cols="30" rows="5" required></textarea>
                     <div class="invalid-feedback">Please add your review !</div>
                 </div>
                 <button type="submit" class=" btn btn-outline-dark">submit</button>
            </form>

          </div>
    </div>

